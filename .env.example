# --- Server ---
NODE_ENV=development
PORT=8080
LOG_LEVEL=debug

# --- Database (Supabase Postgres) ---
# Direct connection (used by application + Drizzle)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
# Optional pooled connection (PgBouncer) — for serverless / short-lived connections
DATABASE_POOL_URL=

# --- Supabase Auth (JWT verification) ---
# Project URL — used to fetch JWKS at /auth/v1/.well-known/jwks.json for
# verifying user access tokens (modern Supabase signs them with ES256).
SUPABASE_URL=https://[PROJECT-REF].supabase.co
# Browser-safe key. CLI v2: sb_publishable_…  (legacy projects: anon key).
# Server doesn't use it — only here so the same .env works for the UI.
SUPABASE_ANON_KEY=
# Server-only key. CLI v2: sb_secret_…  (legacy: service_role key). Optional;
# only needed if the API server calls Supabase admin endpoints.
SUPABASE_SERVICE_ROLE_KEY=
# Legacy HS256 shared secret. Optional. Required only for environments where
# tokens are still HS256 (e.g. integration tests minting their own tokens via
# tests/integration/helpers/auth.ts). Modern access tokens are verified via
# the JWKS endpoint above.
SUPABASE_JWT_SECRET=

# --- LLM (OpenRouter is the only gateway) ---
# Get a key at https://openrouter.ai/keys — one key serves all model providers.
OPENROUTER_API_KEY=
# Identifier shown on OpenRouter's dashboard for usage attribution.
OPENROUTER_REFERER=https://auto-ops.local

# --- Worker / Queue ---
# Polling interval for the task worker (ms)
WORKER_POLL_INTERVAL_MS=2000
# Max concurrent task executions per worker process
WORKER_MAX_CONCURRENCY=4

# --- Cloudflare Images (post-MVP) ---
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_IMAGES_TOKEN=
# Cloudflare Images delivery hash (distinct from account ID).
# Read from the delivery URL of any CF Images upload: imagedelivery.net/{hash}/...
CLOUDFLARE_IMAGES_HASH=

# OpenAI API key — image generation via gpt-image-1
OPENAI_API_KEY=

# --- LangSmith (optional, AI observability) ---
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=auto-ops

# --- Serper.dev SERP API ---
# https://serper.dev — Strategist agent uses this for keyword research.
# v1: platform-wide single key absorbed by the platform.
SERPER_API_KEY=
