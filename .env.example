# --- Server ---
NODE_ENV=development
PORT=8080
LOG_LEVEL=debug

# --- Database (Supabase Postgres) ---
# Direct connection (used by application + Drizzle)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
# Optional pooled connection (PgBouncer) — for serverless / short-lived connections
DATABASE_POOL_URL=

# --- Supabase Auth (JWT verification) ---
SUPABASE_URL=https://[PROJECT-REF].supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# --- LLM (OpenRouter is the only gateway) ---
# Get a key at https://openrouter.ai/keys — one key serves all model providers.
OPENROUTER_API_KEY=
# Identifier shown on OpenRouter's dashboard for usage attribution.
OPENROUTER_REFERER=https://auto-ops.local

# --- Worker / Queue ---
# Polling interval for the task worker (ms)
WORKER_POLL_INTERVAL_MS=2000
# Max concurrent task executions per worker process
WORKER_MAX_CONCURRENCY=4

# --- Cloudflare Images (post-MVP) ---
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_IMAGES_TOKEN=

# --- LangSmith (optional, AI observability) ---
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=auto-ops
